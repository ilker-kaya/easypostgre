# Strong random secret used for session/auth token signing.
AUTH_SECRET=replace-with-at-least-32-random-chars

# Base64-encoded 32-byte key for AES-256-GCM credential encryption.
CREDENTIAL_ENCRYPTION_KEY_BASE64=replace-with-base64-32-byte-key

# Directory where encrypted credential records are stored.
CREDENTIAL_STORAGE_PATH=./data/credentials

# Directory where generated backup files are stored.
BACKUP_STORAGE_PATH=./data/backups

# Directory for long-term/offline backup copies.
BACKUP_ARCHIVE_PATH=./data/backup-archive
